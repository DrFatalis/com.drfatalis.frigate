{
  "id": "com.drfatalis.frigate",
  "version": "1.0.0",
  "compatibility": ">=5.0.0",
  "sdk": 3,
  "brandColor": "#00a0e1",
  "platforms": [
    "local"
  ],
  "name": {
    "en": "Frigate NVR"
  },
  "description": {
    "en": "Integrate Frigate NVR into Homey via MQTT — motion detection, object alerts and camera control"
  },
  "category": [
    "security"
  ],
  "permissions": [],
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "author": {
    "name": "Maxime Salecroix",
    "email": "msalecroix@msx-it-solutions.com"
  },
  "flow": {
    "triggers": [
      {
        "id": "object-detected",
        "title": {
          "en": "Object detected"
        },
        "tokens": [
          {
            "name": "label",
            "type": "string",
            "title": { "en": "Label" },
            "example": "person"
          },
          {
            "name": "sub_label",
            "type": "string",
            "title": { "en": "Sub-label" },
            "example": "John Doe"
          },
          {
            "name": "zones",
            "type": "string",
            "title": { "en": "Zones" },
            "example": "driveway, yard"
          },
          {
            "name": "score",
            "type": "number",
            "title": { "en": "Confidence (%)" },
            "example": 87
          },
          {
            "name": "event_id",
            "type": "string",
            "title": { "en": "Event ID" },
            "example": "1a2b3c4d-5678"
          },
          {
            "name": "snapshot_url",
            "type": "string",
            "title": { "en": "Snapshot URL" },
            "example": "http://192.168.1.100:5000/api/events/abc-123/snapshot.jpg"
          },
          {
            "name": "clip_url",
            "type": "string",
            "title": { "en": "Clip URL" },
            "example": "http://192.168.1.100:5000/api/events/abc-123/clip.mp4"
          },
          {
            "name": "snapshot",
            "type": "image",
            "title": { "en": "Snapshot" }
          }
        ],
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=camera"
          }
        ]
      },
      {
        "id": "review-alert",
        "title": {
          "en": "New review alert"
        },
        "tokens": [
          {
            "name": "review_id",
            "type": "string",
            "title": { "en": "Review ID" },
            "example": "rev-abc123"
          },
          {
            "name": "severity",
            "type": "string",
            "title": { "en": "Severity" },
            "example": "alert"
          },
          {
            "name": "objects",
            "type": "string",
            "title": { "en": "Detected objects" },
            "example": "person, car"
          },
          {
            "name": "zones",
            "type": "string",
            "title": { "en": "Zones" },
            "example": "driveway"
          }
        ],
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=camera"
          }
        ]
      }
    ],
    "conditions": [
      {
        "id": "label-detected-recently",
        "title": {
          "en": "!{{A|No}} label detected recently"
        },
        "titleFormatted": {
          "en": "!{{A|No}} [[label]] detected in last [[minutes]] minutes"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=camera"
          },
          {
            "type": "text",
            "name": "label",
            "placeholder": { "en": "person" }
          },
          {
            "type": "number",
            "name": "minutes",
            "placeholder": { "en": "5" },
            "min": 1,
            "max": 60,
            "step": 1
          }
        ]
      },
      {
        "id": "camera-has-unreviewed-alerts",
        "title": {
          "en": "Camera !{{has|has no}} unreviewed alerts"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=camera"
          }
        ]
      }
    ],
    "actions": [
      {
        "id": "restart-frigate",
        "title": {
          "en": "Restart Frigate"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=camera"
          }
        ]
      },
      {
        "id": "enable-detection",
        "title": {
          "en": "Enable object detection"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=camera"
          }
        ]
      },
      {
        "id": "disable-detection",
        "title": {
          "en": "Disable object detection"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=camera"
          }
        ]
      },
      {
        "id": "enable-recording",
        "title": {
          "en": "Enable recording"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=camera"
          }
        ]
      },
      {
        "id": "disable-recording",
        "title": {
          "en": "Disable recording"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=camera"
          }
        ]
      },
      {
        "id": "enable-snapshots",
        "title": {
          "en": "Enable snapshots"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=camera"
          }
        ]
      },
      {
        "id": "disable-snapshots",
        "title": {
          "en": "Disable snapshots"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=camera"
          }
        ]
      },
      {
        "id": "suspend-notifications",
        "title": {
          "en": "Suspend notifications"
        },
        "titleFormatted": {
          "en": "Suspend notifications for [[minutes]] minutes"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=camera"
          },
          {
            "type": "number",
            "name": "minutes",
            "placeholder": { "en": "30" },
            "min": 1,
            "max": 1440,
            "step": 1
          }
        ]
      }
    ]
  },
  "drivers": [
    {
      "id": "camera",
      "name": {
        "en": "Camera"
      },
      "class": "camera",
      "capabilities": [
        "alarm_motion",
        "detection_fps",
        "event_count",
        "unreviewed_alerts"
      ],
      "platforms": [
        "local"
      ],
      "connectivity": [
        "lan"
      ],
      "images": {
        "small": "/drivers/camera/assets/images/small.png",
        "large": "/drivers/camera/assets/images/large.png",
        "xlarge": "/drivers/camera/assets/images/xlarge.png"
      },
      "pair": [
        {
          "id": "frigate_credentials"
        },
        {
          "id": "frigate_camera"
        }
      ],
      "settings": [
        {
          "id": "mqtt_url",
          "type": "text",
          "label": { "en": "MQTT Broker URL" },
          "value": "mqtt://192.168.1.100:1883",
          "hint": { "en": "e.g. mqtt://192.168.1.100:1883 or mqtts://... for TLS" }
        },
        {
          "id": "mqtt_username",
          "type": "text",
          "label": { "en": "MQTT Username (optional)" },
          "value": ""
        },
        {
          "id": "mqtt_password",
          "type": "password",
          "label": { "en": "MQTT Password (optional)" },
          "value": ""
        },
        {
          "id": "mqtt_topic_prefix",
          "type": "text",
          "label": { "en": "Frigate topic prefix" },
          "value": "frigate",
          "hint": { "en": "topic_prefix set in Frigate config (default: frigate)" }
        },
        {
          "id": "camera_name",
          "type": "text",
          "label": { "en": "Camera name" },
          "value": ""
        },
        {
          "id": "frigate_url",
          "type": "text",
          "label": { "en": "Frigate URL (optional — for snapshot/clip links)" },
          "value": "",
          "hint": { "en": "If set, snapshot_url and clip_url tokens in flows will be populated. e.g. http://192.168.1.100:5000" }
        },
        {
          "id": "label_filter",
          "type": "text",
          "label": { "en": "Label filter (comma-separated, empty = all)" },
          "value": "",
          "hint": { "en": "Only fire the object-detected trigger for these labels, e.g. person,car,dog" }
        }
      ]
    }
  ],
  "capabilities": {
    "detection_fps": {
      "type": "number",
      "title": { "en": "Detection FPS" },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "decimals": 1,
      "insights": false,
      "units": "fps"
    },
    "event_count": {
      "type": "number",
      "title": { "en": "Events today" },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "decimals": 0,
      "insights": true
    },
    "unreviewed_alerts": {
      "type": "number",
      "title": { "en": "Unreviewed alerts" },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "decimals": 0,
      "insights": false
    }
  }
}
